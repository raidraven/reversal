# データベース(PostgreSQLの接続文字列。例: Neon/Supabase/Vercel Postgresなど)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth(`openssl rand -base64 32` などで生成した値を設定)
NEXTAUTH_SECRET="your-nextauth-secret-here"
# 本番では実際の公開URL(https://...)に差し替える
NEXTAUTH_URL="http://localhost:3000"

# Claude API(AIコンパニオン「クロエ」用)
ANTHROPIC_API_KEY="sk-ant-..."

# 館の主(管理者)に自動昇格させるメールアドレス(カンマ区切り、複数可)
# ここに書いたメールでログインすると自動的に /admin ページが閲覧可能になる
ADMIN_EMAILS="you@example.com"

# パスワード再設定メールの送信(Resend: https://resend.com )
# 未設定の場合、送信はスキップされサーバーログにリンクが出力されるだけになる(開発用)
RESEND_API_KEY="re_..."
# 独自ドメイン未認証の場合は "onboarding@resend.dev" を使うとテスト送信できる
EMAIL_FROM="リバーサル <onboarding@resend.dev>"
